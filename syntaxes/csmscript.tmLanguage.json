{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CSMScript",
  "scopeName": "source.csmscript",
  "patterns": [
    { "include": "#line-comment" },
    { "include": "#predef-section" },
    { "include": "#control-flow" },
    { "include": "#anchor" },
    { "include": "#variable-reference" },
    { "include": "#return-value-save" },
    { "include": "#range-operator" },
    { "include": "#string-comparison-function" },
    { "include": "#conditional-jump" },
    { "include": "#builtin-command" },
    { "include": "#subscription-op" },
    { "include": "#broadcast-target-with-op" },
    { "include": "#communication-operator" },
    { "include": "#argument-text" },
    { "include": "#argument-separator" },
    { "include": "#module-address" },
    { "include": "#state-prefix" },
    { "include": "#system-state" }
  ],
  "repository": {
    "line-comment": {
      "comment": "Line comment: // to end of line",
      "name": "comment.line.double-slash.csmscript",
      "match": "//.*$"
    },

    "predef-section": {
      "comment": "Pre-definition area: INI-style section headers [SECTION_NAME] and key = value pairs",
      "patterns": [
        {
          "comment": "INI section header: [SECTION_NAME] — recognized configuration sections",
          "match": "^\\s*(\\[)(COMMAND_ALIAS|Command_Alias|CommandAlias|Command-Alias|Command Alias|CMD_Alias|CMDAlias|CMD-Alias|CMD Alias|AUTO_ERROR_HANDLE|INI_VAR_SPACE|TAGDB_VAR_SPACE)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.section.csmscript" },
            "2": { "name": "entity.name.section.predef.csmscript" },
            "3": { "name": "punctuation.definition.section.csmscript" }
          }
        },
        {
          "comment": "INI key-value pair: key = value (in pre-definition area)",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_\\- ]*)\\s*(=)\\s*(.+)$",
          "captures": {
            "1": { "name": "variable.other.predef-key.csmscript" },
            "2": { "name": "keyword.operator.assignment.csmscript" },
            "3": { "name": "string.unquoted.predef-value.csmscript" }
          }
        }
      ]
    },

    "control-flow": {
      "comment": "CSMScript control flow constructs and include directive",
      "patterns": [
        {
          "comment": "Simple no-expression control flow tags: <else>, <end_if>, <end_while>, <do_while>, <end_foreach>",
          "name": "keyword.control.flow.csmscript",
          "match": "<(?:else|end_if|end_while|do_while|end_foreach)>"
        },
        {
          "comment": "Include directive: <include filepath.csmscript>",
          "match": "(<)(include)(\\s+)([^>]+)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.csmscript" },
            "2": { "name": "keyword.control.include.csmscript" },
            "4": { "name": "string.unquoted.include-path.csmscript" },
            "5": { "name": "punctuation.definition.tag.csmscript" }
          }
        },
        {
          "comment": "Control flow with expression (greedy close bracket captures last > on line): <if expr>, <while expr>, <end_do_while expr>, <foreach var in list>",
          "match": "(<)(if|while|end_do_while|foreach)(\\b.*)(>)(?=\\s*(?://.*)?$)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.csmscript" },
            "2": { "name": "keyword.control.flow.csmscript" },
            "4": { "name": "punctuation.definition.tag.csmscript" }
          }
        }
      ]
    },

    "anchor": {
      "comment": "Anchor label: <anchor_name> — any <word> not consumed by other patterns",
      "name": "entity.name.label.anchor.csmscript",
      "match": "<[A-Za-z_][A-Za-z0-9_-]*>"
    },

    "variable-reference": {
      "comment": "Variable reference: ${varname} or ${varname:default}",
      "patterns": [
        {
          "comment": "Variable with default value: ${varname:default}",
          "match": "(\\$\\{)([^}:]+)(:)([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.variable.csmscript" },
            "2": { "name": "variable.other.csmscript" },
            "3": { "name": "punctuation.separator.default.csmscript" },
            "4": { "name": "markup.italic markup.underline string.unquoted.variable-default.csmscript" },
            "5": { "name": "punctuation.definition.variable.csmscript" }
          }
        },
        {
          "comment": "Simple variable reference: ${varname}",
          "match": "(\\$\\{)([^}]+)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.variable.csmscript" },
            "2": { "name": "variable.other.csmscript" },
            "3": { "name": "punctuation.definition.variable.csmscript" }
          }
        }
      ]
    },

    "return-value-save": {
      "comment": "Return value save operator: => varname (saves instruction return value to variable)",
      "match": "(=>)\\s*([_a-zA-Z][_a-zA-Z0-9;\\-]*)",
      "captures": {
        "1": { "name": "keyword.operator.return-save.csmscript" },
        "2": { "name": "variable.other.assignment.csmscript" }
      }
    },

    "range-operator": {
      "comment": "Range membership operators: ∈ (in range) and !∈ (not in range)",
      "patterns": [
        {
          "comment": "Not-in-range: !∈",
          "name": "keyword.operator.range-not-in.csmscript",
          "match": "!∈"
        },
        {
          "comment": "In-range: ∈",
          "name": "keyword.operator.range-in.csmscript",
          "match": "∈"
        }
      ]
    },

    "string-comparison-function": {
      "comment": "String comparison helpers used in EXPRESSION, e.g. equal(...), match(...), belong(...)",
      "name": "support.function.string-compare.csmscript",
      "match": "(?i)\\b(equal|equal_s|match|match_s|start_with|start_with_s|end_with|end_with_s|contain|contain_s|belong|belong_s)(?=\\s*\\()"
    },

    "conditional-jump": {
      "comment": "Conditional jump syntax: ?? goto (on error) or ?expression? goto (on condition)",
      "patterns": [
        {
          "comment": "Conditional jump with expression: ?expression? goto >> <anchor>",
          "match": "(\\?)([^?]*)(\\?)\\s*(goto|GOTO)\\b",
          "captures": {
            "1": { "name": "keyword.operator.conditional-jump.csmscript" },
            "2": { "name": "meta.expression.conditional-jump.csmscript" },
            "3": { "name": "keyword.operator.conditional-jump.csmscript" },
            "4": { "name": "keyword.control.jump.csmscript" }
          }
        },
        {
          "comment": "Error jump: ?? goto >> <anchor>",
          "match": "(\\?\\?)\\s*(goto|GOTO)\\b",
          "captures": {
            "1": { "name": "keyword.operator.error-jump.csmscript" },
            "2": { "name": "keyword.control.jump.csmscript" }
          }
        }
      ]
    },

    "builtin-command": {
      "comment": "CSMScript built-in commands (case-insensitive)",
      "patterns": [
        {
          "comment": "Jump / goto commands",
          "name": "keyword.control.jump.csmscript",
          "match": "(?i)\\b(GOTO|JUMP)\\b"
        },
        {
          "comment": "Wait / sleep commands (with optional unit suffix)",
          "name": "keyword.control.wait.csmscript",
          "match": "(?i)\\b(WAIT(?:\\(s\\)|\\(ms\\))?|SLEEP(?:\\(s\\)|\\(ms\\))?)\\b"
        },
        {
          "comment": "Loop control",
          "name": "keyword.control.loop.csmscript",
          "match": "(?i)\\b(BREAK|CONTINUE)\\b"
        },
        {
          "comment": "Auto error handle enable/anchor",
          "name": "keyword.other.auto-error.csmscript",
          "match": "(?i)\\b(AUTO_ERROR_HANDLE_ENABLE|AUTO_ERROR_HANDLE_ANCHOR)\\b"
        },
        {
          "comment": "Echo output commands (ECHO, ECHO0-ECHO9)",
          "name": "support.function.echo.csmscript",
          "match": "(?i)\\b(ECHO[0-9]?)\\b"
        },
        {
          "comment": "Expression evaluation",
          "name": "support.function.expression.csmscript",
          "match": "(?i)\\b(EXPRESSION)\\b"
        },
        {
          "comment": "Random number generation",
          "name": "support.function.random.csmscript",
          "match": "(?i)\\b(RANDOM(?:DBL|INT|\\(DBL\\)|\\(INT\\))?)\\b"
        },
        {
          "comment": "Dialog commands",
          "name": "support.function.dialog.csmscript",
          "match": "(?i)\\b(ONE_BUTTON_DIALOG|TWO_BUTTON_DIALOG|CONFIRM_DIALOG|INPUT_DIALOG)\\b"
        },
        {
          "comment": "INI variable space commands",
          "name": "keyword.other.ini-var.csmscript",
          "match": "(?i)\\b(INI_VAR_SPACE_ENABLE|INI_VAR_SPACE_PATH)\\b"
        },
        {
          "comment": "TagDB variable space configuration commands",
          "name": "keyword.other.tagdb.csmscript",
          "match": "(?i)\\b(TAGDB_VAR_SPACE_ENABLE|TAGDB_VAR_SPACE_NAME)\\b"
        },
        {
          "comment": "TagDB data operation commands",
          "name": "support.function.tagdb.csmscript",
          "match": "(?i)\\b(TAGDB_GET_VALUE|TAGDB_SET_VALUE|TAGDB_SWEEP|TAGDB_WAIT_FOR_EXPRESSION|TAGDB_START_MONITOR_EXPRESSION|TAGDB_STOP_MONITOR_EXPRESSION|TAGDB_WAIT_FOR_STABLE)\\b"
        }
      ]
    },

    "subscription-op": {
      "comment": "Subscription/unsubscription operations: -><register>, -><unregister>, -><register as interrupt/status>",
      "patterns": [
        {
          "comment": "Register with priority change: -><register as interrupt> or -><register as status>",
          "match": "(-><)(register\\s+as\\s+(?:interrupt|status|Interrupt|Status))(>)",
          "captures": {
            "1": { "name": "keyword.operator.subscription.csmscript" },
            "2": { "name": "keyword.control.subscription-type.csmscript" },
            "3": { "name": "keyword.operator.subscription.csmscript" }
          }
        },
        {
          "comment": "Register or unregister subscription: -><register> or -><unregister>",
          "match": "(-><)(register|unregister)(>)",
          "captures": {
            "1": { "name": "keyword.operator.subscription.csmscript" },
            "2": { "name": "keyword.control.subscription.csmscript" },
            "3": { "name": "keyword.operator.subscription.csmscript" }
          }
        }
      ]
    },

    "broadcast-target-with-op": {
      "comment": "Send operators with their targets: broadcast targets and module names",
      "patterns": [
        {
          "comment": "Interrupt broadcast target: -> <interrupt>",
          "match": "(->)\\s*(<interrupt>)",
          "captures": {
            "1": { "name": "keyword.operator.async-call.csmscript" },
            "2": { "name": "constant.language.interrupt-target.csmscript" }
          }
        },
        {
          "comment": "Normal broadcast targets: -> <status>, -> <broadcast>, -> <all>",
          "match": "(->)\\s*(<(?:status|broadcast|all)>)",
          "captures": {
            "1": { "name": "keyword.operator.async-call.csmscript" },
            "2": { "name": "constant.language.broadcast-target.csmscript" }
          }
        },
        {
          "comment": "Synchronous call with target module: -@ ModuleName",
          "match": "(-@)\\s+([\\w][\\w\\-]*)",
          "captures": {
            "1": { "name": "keyword.operator.sync-call.csmscript" },
            "2": { "name": "entity.name.namespace.module.csmscript" }
          }
        },
        {
          "comment": "Async no-reply with target module: ->| ModuleName (->| before -> to avoid partial match)",
          "match": "(->\\|)\\s+([\\w][\\w\\-]*)",
          "captures": {
            "1": { "name": "keyword.operator.async-no-reply.csmscript" },
            "2": { "name": "entity.name.namespace.module.csmscript" }
          }
        },
        {
          "comment": "Async call with target module: -> ModuleName",
          "match": "(->)\\s+([\\w][\\w\\-]*)",
          "captures": {
            "1": { "name": "keyword.operator.async-call.csmscript" },
            "2": { "name": "entity.name.namespace.module.csmscript" }
          }
        }
      ]
    },

    "communication-operator": {
      "comment": "Inter-module communication operators",
      "patterns": [
        {
          "comment": "Async call without reply: ->|",
          "name": "keyword.operator.async-no-reply.csmscript",
          "match": "->\\|"
        },
        {
          "comment": "Synchronous call: -@",
          "name": "keyword.operator.sync-call.csmscript",
          "match": "-@"
        },
        {
          "comment": "Asynchronous call with reply: ->",
          "name": "keyword.operator.async-call.csmscript",
          "match": "->"
        }
      ]
    },

    "argument-separator": {
      "comment": ">> separates state/API name from its arguments",
      "name": "keyword.operator.argument-separator.csmscript",
      "match": ">>"
    },

    "argument-text": {
      "comment": "Arguments that appear after >> and before communication/subscription operators",
      "begin": ">>\\s*",
      "beginCaptures": {
        "0": { "name": "keyword.operator.argument-separator.csmscript" }
      },
      "end": "(?=\\s*(?:-@|->\\|?|-><|=>|$))",
      "contentName": "markup.italic markup.underline string.unquoted.argument.csmscript",
      "patterns": [
        { "include": "#anchor" },
        { "include": "#control-flow" },
        { "include": "#variable-reference" },
        { "include": "#module-address" }
      ]
    },

    "module-address": {
      "comment": "Module reference: @ModuleName — source/target module separator with optional module name (e.g. Status@SourceModule). Maps to Name::Label: bold, inherits color. The module name is optional to allow @-only edge cases.",
      "match": "(@)([\\w][\\w\\-]*)?",
      "captures": {
        "1": { "name": "punctuation.separator.module.csmscript" },
        "2": { "name": "entity.name.label.module-address.csmscript" }
      }
    },

    "state-prefix": {
      "comment": "Conventional state name prefixes API: and Macro:",
      "patterns": [
        {
          "comment": "API state prefix: API:",
          "match": "\\b(API)(:)",
          "captures": {
            "1": { "name": "keyword.other.api-prefix.csmscript" },
            "2": { "name": "punctuation.separator.prefix.csmscript" }
          }
        },
        {
          "comment": "Macro state prefix: Macro:",
          "match": "\\b(Macro)(:)",
          "captures": {
            "1": { "name": "keyword.other.macro-prefix.csmscript" },
            "2": { "name": "punctuation.separator.prefix.csmscript" }
          }
        }
      ]
    },

    "system-state": {
      "comment": "CSM framework built-in state names. Multi-word names use lookahead/lookbehind instead of \\b to avoid ambiguity with spaces.",
      "patterns": [
        {
          "comment": "Multi-word system states",
          "name": "support.constant.system-state.csmscript",
          "match": "(?<![^\\s])(Async Message Posted|Async Response|Target Timeout Error|Target Error|Critical Error|No Target Error|Error Handler)(?=[\\s>]|$)"
        },
        {
          "comment": "Single-word system state",
          "name": "support.constant.system-state.csmscript",
          "match": "\\b(Response)\\b"
        }
      ]
    }
  }
}
